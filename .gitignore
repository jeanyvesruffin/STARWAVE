# ============================================================
#  STARWAVE — .gitignore multimodule
#  Java (Spring Boot) · Python (FastAPI) · Node (Angular 21)
#  Docker · Kubernetes · Terraform · Secrets
# ============================================================


# ────────────────────────────────────────────────────────────
#  SECRETS & CREDENTIALS  (toujours en premier)
# ────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.p12
*.jks
*.keystore
*.truststore
secrets/
**/secrets/
*secret*
*credential*
*password*
*token*
service-account*.json
gcp-key*.json
aws-credentials
.aws/
.gcp/
kubeconfig
kubeconfig.*
**/kubeconfig


# ────────────────────────────────────────────────────────────
#  JAVA / SPRING BOOT  (backend/)
# ────────────────────────────────────────────────────────────
# Build
backend/target/
gateway/target/
backend/.mvn/wrapper/maven-wrapper.jar
!backend/.mvn/wrapper/maven-wrapper.properties

# Logs
backend/logs/
backend/*.log

# Spring Boot
backend/application-local.yml
backend/application-local.properties
backend/application-dev.yml
backend/application-dev.properties
backend/**/application-secret*.yml
backend/**/application-secret*.properties

# IDE
backend/.idea/
backend/*.iml
backend/.classpath
backend/.project
backend/.settings/
backend/.factorypath


# ────────────────────────────────────────────────────────────
#  PYTHON — workers/ · crossmatch/ · spectral/
# ────────────────────────────────────────────────────────────
# Environnements virtuels
**/venv/
**/.venv/
**/env/
**/.env/
**/__pypackages__/

# Cache Python
**/__pycache__/
**/*.py[cod]
**/*.pyo
**/*.pyd
**/.Python

# Distribution / packaging
**/dist/
**/build/
**/*.egg-info/
**/*.egg
**/.eggs/
**/sdist/
**/wheels/

# Tests & coverage
**/.pytest_cache/
**/.coverage
**/coverage.xml
**/htmlcov/
**/.tox/
**/.mypy_cache/
**/.ruff_cache/
**/.hypothesis/

# Jupyter
**/.ipynb_checkpoints/
**/profile_default/
**/ipython_config.py

# PyInstaller
**/*.spec

# GPU / ML artefacts
**/checkpoints/
**/weights/
**/models/
**/*.pt
**/*.pth
**/*.ckpt
**/*.onnx
**/*.safetensors
**/mlruns/
**/wandb/
**/lightning_logs/

# FastAPI
workers/*.log
crossmatch/*.log
spectral/*.log


# ────────────────────────────────────────────────────────────
#  NODE / ANGULAR  (frontend/)
# ────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/.pnp
frontend/.pnp.js
frontend/.yarn/cache
frontend/.yarn/unplugged
frontend/.yarn/build-state.yml
frontend/.yarn/install-state.gz

# Build Angular
frontend/dist/
frontend/.angular/

# Cache & logs
frontend/.npm/
frontend/.eslintcache
frontend/*.log
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# Tests
frontend/coverage/


# ────────────────────────────────────────────────────────────
#  DOCKER  (infra/docker/)
# ────────────────────────────────────────────────────────────
infra/docker/.env
infra/docker/.env.*
!infra/docker/.env.example
**/docker-compose.override.yml
**/docker-compose.local.yml


# ────────────────────────────────────────────────────────────
#  KUBERNETES  (infra/k8s/ · infra/helm/)
# ────────────────────────────────────────────────────────────
infra/k8s/**/*-secret.yaml
infra/k8s/**/*-secrets.yaml
infra/helm/**/*-secret.yaml
infra/helm/**/*-secrets.yaml
infra/helm/**/values-local.yaml
infra/helm/**/values-dev.yaml
infra/helm/**/values-prod.yaml
!infra/helm/**/values.yaml
!infra/helm/**/values.example.yaml

# Helm temporaire
infra/helm/**/*.tgz


# ────────────────────────────────────────────────────────────
#  TERRAFORM  (infra/terraform/)
# ────────────────────────────────────────────────────────────
infra/terraform/.terraform/
infra/terraform/.terraform.lock.hcl
infra/terraform/terraform.tfstate
infra/terraform/terraform.tfstate.*
infra/terraform/terraform.tfstate.backup
infra/terraform/*.tfvars
!infra/terraform/*.tfvars.example
infra/terraform/override.tf
infra/terraform/override.tf.json
infra/terraform/*_override.tf
infra/terraform/*_override.tf.json
infra/terraform/crash.log
infra/terraform/crash.*.log


# ────────────────────────────────────────────────────────────
#  DOCS
# ────────────────────────────────────────────────────────────
docs/_site/
docs/.sass-cache/
docs/.jekyll-cache/


# ────────────────────────────────────────────────────────────
#  IDEs & ÉDITEURS
# ────────────────────────────────────────────────────────────
# IntelliJ / PyCharm / WebStorm
.idea/
*.iml
*.iws
*.ipr
out/

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# Eclipse
.classpath
.project
.settings/
.factorypath

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.\#*


# ────────────────────────────────────────────────────────────
#  OS
# ────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini


# ────────────────────────────────────────────────────────────
#  LOGS & TEMPORAIRES (global)
# ────────────────────────────────────────────────────────────
*.log
*.tmp
*.temp
*.bak
*.orig
*.pid
*.seed
*.pid.lock
tmp/
temp/
